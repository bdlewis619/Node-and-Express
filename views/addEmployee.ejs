<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Employee</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f7fb;
            color: #0f172a;
        }
        .page {
            max-width: 720px;
            margin: 0 auto;
            padding: 24px;
        }
        .card {
            background: #ffffff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        }
        .back-link {
            display: inline-block;
            margin-bottom: 16px;
            color: #0ea5e9;
            text-decoration: none;
            font-weight: 700;
        }
        .form-grid {
            display: grid;
            gap: 14px;
        }
        label {
            display: block;
            margin-bottom: 6px;
            font-weight: 700;
        }
        input {
            width: 100%;
            box-sizing: border-box;
            padding: 10px 12px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 15px;
        }
        .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 8px;
        }
        button,
        .button-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 14px;
            border: 0;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 700;
            cursor: pointer;
            font-size: 15px;
        }
        button[type="submit"] {
            background: #38bdf8;
            color: #00111f;
        }
        .button-link {
            background: #e2e8f0;
            color: #0f172a;
        }
        .notice {
            margin-bottom: 16px;
            padding: 14px 16px;
            background: #f8fafc;
            border-left: 4px solid #0ea5e9;
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="page">
        <a class="back-link" href="/api/dashboard">Back to Dashboard</a>
        <div class="card">
            <h1 style="margin-top:0;">Add New Employee</h1>
            <% if (typeof msg !== 'undefined' && msg) { %>
                <div class="notice"><%= msg %></div>
            <% } %>

            <form class="form-grid" action="/api/addEmployee" method="POST">
                <div>
                    <label for="name">Name:</label>
                    <input type="text" id="name" name="name" placeholder="Lastname, Firstname" required>
                </div>

                <div>
                    <label for="email">Email:</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div>
                    <label for="designation">Designation:</label>
                    <input type="text" id="designation" name="designation" required>
                </div>

                <div>
                    <label for="contact">Contact:</label>
                    <input type="text" id="contact" name="contact" required>
                </div>

                <div>
                    <label for="department">Department:</label>
                    <input type="text" id="department" name="department">
                </div>

                <div>
                    <label for="joiningDate">Joining Date:</label>
                    <input type="date" id="joiningDate" name="joiningDate">
                </div>

                <div>
                    <label for="location">Location:</label>
                    <input type="text" id="location" name="location">
                </div>

                <div class="actions">
                    <button type="submit">Add Employee</button>
                    <a class="button-link" href="/api/dashboard">Cancel</a>
                </div>
            </form>

            <% if (typeof employee !== 'undefined' && employee) { %>
                <h2>Created Employee</h2>
                <pre><%= JSON.stringify(employee, null, 2) %></pre>
            <% } %>
        </div>
    </div>
</body>
</html>