<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Login</title>
	<style>
		:root {
			--bg: #0f172a;
			--panel: rgba(15, 23, 42, 0.88);
			--panel-border: rgba(148, 163, 184, 0.22);
			--text: #e2e8f0;
			--muted: #94a3b8;
			--accent: #38bdf8;
			--accent-strong: #0ea5e9;
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			min-height: 100vh;
			font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
			color: var(--text);
			background:
				radial-gradient(circle at top left, rgba(56, 189, 248, 0.28), transparent 30%),
				radial-gradient(circle at top right, rgba(34, 197, 94, 0.18), transparent 28%),
				linear-gradient(135deg, #020617 0%, #0f172a 45%, #111827 100%);
			display: grid;
			place-items: center;
			padding: 24px;
		}

		.card {
			width: min(100%, 960px);
			display: grid;
			grid-template-columns: 1.1fr 0.9fr;
			border: 1px solid var(--panel-border);
			border-radius: 24px;
			overflow: hidden;
			background: var(--panel);
			box-shadow: 0 24px 80px rgba(2, 6, 23, 0.45);
			backdrop-filter: blur(14px);
		}

		.hero {
			padding: 48px;
			background:
				linear-gradient(160deg, rgba(14, 165, 233, 0.16), rgba(15, 23, 42, 0.08)),
				linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0));
		}

		.eyebrow {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			padding: 8px 14px;
			border-radius: 999px;
			background: rgba(56, 189, 248, 0.12);
			color: #7dd3fc;
			font-size: 0.85rem;
			letter-spacing: 0.04em;
			text-transform: uppercase;
		}

		h1 {
			margin: 18px 0 12px;
			font-size: clamp(2.2rem, 5vw, 4rem);
			line-height: 1;
		}

		.lead {
			margin: 0;
			max-width: 34rem;
			color: var(--muted);
			font-size: 1rem;
			line-height: 1.7;
		}

		.quick-actions {
			margin-top: 28px;
			display: grid;
			gap: 12px;
		}

		.action-row {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.button {
			appearance: none;
			border: 0;
			border-radius: 14px;
			padding: 10px 14px;
			font-weight: 700;
			font-size: 0.95rem;
			text-decoration: none;
			cursor: pointer;
			transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 120px;
		}

		.button:hover {
			transform: translateY(-1px);
		}

		.button-primary {
			background: linear-gradient(135deg, var(--accent), var(--accent-strong));
			color: #00111f;
			box-shadow: 0 12px 24px rgba(14, 165, 233, 0.28);
		}

		.button-secondary {
			background: rgba(148, 163, 184, 0.12);
			color: var(--text);
			border: 1px solid rgba(148, 163, 184, 0.2);
		}

		.button-success {
			background: rgba(34, 197, 94, 0.16);
			color: #bbf7d0;
			border: 1px solid rgba(34, 197, 94, 0.22);
		}

		.form-panel {
			padding: 48px;
			border-left: 1px solid var(--panel-border);
			background: rgba(15, 23, 42, 0.58);
		}

		.form-panel h2 {
			margin: 0 0 8px;
			font-size: 1.7rem;
		}

		.form-panel p {
			margin: 0 0 24px;
			color: var(--muted);
			line-height: 1.6;
		}

		.message {
			margin: 0 0 18px;
			padding: 12px 14px;
			border-radius: 12px;
			background: rgba(59, 130, 246, 0.12);
			color: #dbeafe;
			border: 1px solid rgba(59, 130, 246, 0.18);
		}

		.field {
			margin-bottom: 16px;
		}

		label {
			display: block;
			margin-bottom: 8px;
			color: #cbd5e1;
			font-size: 0.95rem;
		}

		input {
			width: 100%;
			padding: 14px 16px;
			border-radius: 14px;
			border: 1px solid rgba(148, 163, 184, 0.22);
			background: rgba(15, 23, 42, 0.9);
			color: var(--text);
			outline: none;
		}

		input:focus {
			border-color: rgba(56, 189, 248, 0.8);
			box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
		}

		.form-actions {
			display: flex;
			gap: 12px;
			flex-wrap: wrap;
			margin-top: 22px;
		}

		.links {
			margin-top: 20px;
			display: flex;
			flex-wrap: wrap;
			gap: 10px 16px;
			font-size: 0.95rem;
		}

		.links a {
			color: #7dd3fc;
			text-decoration: none;
		}

		.links a:hover {
			text-decoration: underline;
		}

		.route-list {
			margin-top: 24px;
			padding: 16px;
			border-radius: 16px;
			border: 1px solid rgba(148, 163, 184, 0.18);
			background: rgba(2, 6, 23, 0.35);
		}

		.route-list h3 {
			margin: 0 0 12px;
			font-size: 1rem;
			color: #cbd5e1;
		}

		.route-list ul {
			margin: 0;
			padding-left: 18px;
			color: var(--muted);
			line-height: 1.8;
		}

		@media (max-width: 840px) {
			.card {
				grid-template-columns: 1fr;
			}

			.form-panel {
				border-left: 0;
				border-top: 1px solid var(--panel-border);
			}
		}

		@media (max-width: 640px) {
			.hero,
			.form-panel {
				padding: 28px;
			}

			.button {
				width: 100%;
			}
		}
	</style>
</head>
<body>
	<main class="card">
		<section class="hero">
			<span class="eyebrow">Employee access portal</span>
			<h1>Welcome back</h1>
			<p class="lead">
				Sign in to manage employee data, view the dashboard, or jump to the other routes exposed in <strong>app.js</strong>.
			</p>

			<!-- Navigation and route list removed; moved to dashboard -->
		</section>

		<section class="form-panel">
			<h2>Login</h2>
			<p>Use your email ID and password to access the dashboard.</p>

			<% if (typeof msg !== 'undefined' && msg) { %>
				<div class="message"><%= msg %></div>
			<% } %>

			<form action="/signIn" method="post">
				<div class="field">
					<label for="emailID">Email ID</label>
					<input type="email" id="emailID" name="emailID" placeholder="name@example.com" required>
				</div>

				<div class="field">
					<label for="password">Password</label>
					<input type="password" id="password" name="password" placeholder="Enter your password" required>
				</div>

				<div class="form-actions">
					<button class="button button-primary" type="submit">Sign In</button>
					<a class="button button-secondary" href="/signUpPage">Sign Up</a>
				</div>
			</form>

			<!-- Employee links removed; available from dashboard -->
		</section>
	</main>
</body>
</html>
