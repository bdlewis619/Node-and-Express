<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f7fb;
            color: #0f172a;
        }
        .page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 24px;
        }
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }
        .logout {
            text-decoration: none;
            color: #ffffff;
            background: #dc2626;
            padding: 10px 14px;
            border-radius: 8px;
            font-weight: 700;
        }
        .card {
            background: #ffffff;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            margin-bottom: 24px;
        }
        .actions {
            display: flex;
            gap: 12px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .actions a {
            padding: 10px 14px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 700;
            color: #00111f;
        }
        .table-wrap {
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1100px;
            background: #ffffff;
        }
        th, td {
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
            white-space: nowrap;
        }
        th {
            background: #0f172a;
            color: #ffffff;
        }
        th a {
            color: inherit;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .filters {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
            margin-top: 16px;
        }
        .filters input {
            width: 100%;
            box-sizing: border-box;
            padding: 10px 12px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
        }
        .filters button {
            padding: 10px 14px;
            border: 0;
            border-radius: 8px;
            background: #0ea5e9;
            color: #ffffff;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
        }
        .empty {
            padding: 18px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="topbar">
            <h2 style="margin:0;">Welcome to the Employee Management Dashboard<%= typeof emailID !== 'undefined' ? ', ' + emailID : '' %></h2>
            <a class="logout" href="/">Logout</a>
        </div>

        <% if (typeof msg !== 'undefined' && msg) { %>
            <section class="card" style="border-left: 4px solid #0ea5e9; margin-bottom: 18px;">
                <strong><%= msg %></strong>
            </section>
        <% } %>

        <section class="card">
            <h3 style="margin-top:0;">Employee Table</h3>

            <% const safeCurrentSort = typeof currentSort !== 'undefined' ? currentSort : 'id'; %>
            <% const safeCurrentOrder = typeof currentOrder !== 'undefined' ? currentOrder : 'asc'; %>
            <% const safeFilters = typeof filters !== 'undefined' ? filters : { search: '', designation: '', department: '', location: '' }; %>
            <% const searchValue = safeFilters.search || ''; %>
            <% const designationValue = safeFilters.designation || ''; %>
            <% const departmentValue = safeFilters.department || ''; %>
            <% const locationValue = safeFilters.location || ''; %>
            <% const filterQuery = `search=${encodeURIComponent(searchValue || '')}&designation=${encodeURIComponent(designationValue || '')}&department=${encodeURIComponent(departmentValue || '')}&location=${encodeURIComponent(locationValue || '')}`; %>

            <form class="filters" method="GET" action="/api/dashboard">
                <input type="hidden" name="sort" value="<%= safeCurrentSort %>">
                <input type="hidden" name="order" value="<%= safeCurrentOrder %>">
                <input type="text" name="search" value="<%= searchValue %>" placeholder="Search by ID or name">
                <input type="text" name="designation" value="<%= designationValue %>" placeholder="Filter by designation">
                <input type="text" name="department" value="<%= departmentValue %>" placeholder="Filter by department">
                <input type="text" name="location" value="<%= locationValue %>" placeholder="Filter by location">
                <button type="submit">Apply Filters</button>
                <a href="/api/addEmployee" style="display:inline-flex; align-items:center; justify-content:center; padding:10px 14px; border:0; border-radius:8px; background:#38f83e; color:#ffffff; font-weight:700; text-decoration:none; cursor:pointer;">Add Employee</a>

            </form>

            <% if (typeof employees !== 'undefined' && employees.length) { %>
            <div class="table-wrap" style="margin-top:16px;">
                <table>
                    <thead>
                        <tr>
                            <% const nextIdOrder = safeCurrentSort === 'id' && safeCurrentOrder === 'asc' ? 'desc' : 'asc'; %>
                            <% const nextNameOrder = safeCurrentSort === 'name' && safeCurrentOrder === 'asc' ? 'desc' : 'asc'; %>
                            <th><a href="/api/dashboard?<%= filterQuery %>&sort=id&order=<%= nextIdOrder %>">ID</a></th>
                            <th><a href="/api/dashboard?<%= filterQuery %>&sort=name&order=<%= nextNameOrder %>">Employees</a></th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th>Contact</th>
                            <th>Department</th>
                            <th>Joining Date</th>
                            <th>Location</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% employees.forEach(function(employee) { %>
                        <tr>
                            <td><%= employee.id %></td>
                            <td><a href="/api/viewEmployee/<%= employee.id %>" style="text-decoration: none; color: #0f172a; font-weight: bold;"><%= employee.name %></a></td>
                            <td><%= employee.designation %></td>
                            <td><%= employee.email %></td>
                            <td><%= employee.contact %></td>
                            <td><%= employee.department %></td>
                            <td><%= employee.joiningDate %></td>
                            <td><%= employee.location %></td>
                            <td>
                                <a href="/api/updateEmployee/<%= employee.id %>" style="background:#38bdf8; padding: 6px 10px; border-radius: 4px; text-decoration: none; color: #00111f; font-size: 12px;">Edit</a>
                                <a href="/api/deleteEmployee/<%= employee.id %>" style="background:#f87171; padding: 6px 10px; border-radius: 4px; text-decoration: none; color: #00111f; font-size: 12px; margin-left: 4px;">Delete</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div class="empty" style="margin-top:16px;">No employee data is available yet.</div>
            <% } %>
        </section>
    </div>
</body>
