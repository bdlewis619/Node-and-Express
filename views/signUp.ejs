<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Sign Up</title>
	<style>
		:root {
			--bg: #07111f;
			--panel: rgba(8, 15, 28, 0.88);
			--panel-border: rgba(148, 163, 184, 0.22);
			--text: #e5eefb;
			--muted: #9aa9bd;
			--accent: #f59e0b;
			--accent-strong: #fb7185;
			--accent-soft: rgba(245, 158, 11, 0.14);
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			min-height: 100vh;
			display: grid;
			place-items: center;
			padding: 24px;
			color: var(--text);
			font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
			background:
				radial-gradient(circle at top left, rgba(245, 158, 11, 0.24), transparent 30%),
				radial-gradient(circle at top right, rgba(251, 113, 133, 0.16), transparent 24%),
				linear-gradient(135deg, #020617 0%, #07111f 45%, #111827 100%);
		}

		.card {
			width: min(100%, 980px);
			display: grid;
			grid-template-columns: 1fr 1fr;
			overflow: hidden;
			border-radius: 24px;
			border: 1px solid var(--panel-border);
			background: var(--panel);
			box-shadow: 0 26px 80px rgba(2, 6, 23, 0.48);
			backdrop-filter: blur(16px);
		}

		.hero {
			padding: 48px;
			background:
				linear-gradient(155deg, rgba(245, 158, 11, 0.16), rgba(15, 23, 42, 0.04)),
				linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0));
		}

		.eyebrow {
			display: inline-flex;
			align-items: center;
			gap: 10px;
			padding: 8px 14px;
			border-radius: 999px;
			background: rgba(245, 158, 11, 0.13);
			color: #fde68a;
			font-size: 0.84rem;
			letter-spacing: 0.04em;
			text-transform: uppercase;
		}

		h1 {
			margin: 18px 0 12px;
			font-size: clamp(2.2rem, 5vw, 4rem);
			line-height: 1;
		}

		.lead {
			margin: 0;
			max-width: 36rem;
			color: var(--muted);
			line-height: 1.7;
		}

		.route-grid {
			margin-top: 28px;
			display: grid;
			gap: 12px;
		}

		.row {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 120px;
			padding: 10px 14px;
			border-radius: 14px;
			border: 0;
			text-decoration: none;
			font-weight: 700;
			font-size: 0.95rem;
			cursor: pointer;
			transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
		}

		.button:hover {
			transform: translateY(-1px);
		}

		.button-primary {
			background: linear-gradient(135deg, var(--accent), var(--accent-strong));
			color: #1a0f00;
			box-shadow: 0 12px 24px rgba(245, 158, 11, 0.26);
		}

		.button-secondary {
			background: rgba(148, 163, 184, 0.12);
			color: var(--text);
			border: 1px solid rgba(148, 163, 184, 0.18);
		}

		.button-dark {
			background: rgba(15, 23, 42, 0.84);
			color: #dbeafe;
			border: 1px solid rgba(148, 163, 184, 0.16);
		}

		.route-list {
			margin-top: 24px;
			padding: 16px;
			border-radius: 16px;
			border: 1px solid rgba(148, 163, 184, 0.16);
			background: rgba(2, 6, 23, 0.36);
		}

		.route-list h3 {
			margin: 0 0 12px;
			font-size: 1rem;
			color: #d6e0ef;
		}

		.route-list ul {
			margin: 0;
			padding-left: 18px;
			color: var(--muted);
			line-height: 1.8;
		}

		.form-panel {
			padding: 48px;
			border-left: 1px solid var(--panel-border);
			background: rgba(15, 23, 42, 0.56);
		}

		.form-panel h2 {
			margin: 0 0 8px;
			font-size: 1.7rem;
		}

		.form-panel p {
			margin: 0 0 22px;
			color: var(--muted);
			line-height: 1.6;
		}

		.message {
			margin: 0 0 18px;
			padding: 12px 14px;
			border-radius: 12px;
			background: rgba(245, 158, 11, 0.12);
			color: #fde68a;
			border: 1px solid rgba(245, 158, 11, 0.18);
		}

		.field {
			margin-bottom: 16px;
		}

		label {
			display: block;
			margin-bottom: 8px;
			color: #dbeafe;
			font-size: 0.95rem;
		}

		input {
			width: 100%;
			padding: 14px 16px;
			border-radius: 14px;
			border: 1px solid rgba(148, 163, 184, 0.22);
			background: rgba(15, 23, 42, 0.9);
			color: var(--text);
			outline: none;
		}

		input:focus {
			border-color: rgba(245, 158, 11, 0.8);
			box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.12);
		}

		.form-actions {
			display: flex;
			gap: 8px;
			margin-top: 18px;
			align-items: center;
			flex-wrap: nowrap;
		}

		.links {
			margin-top: 20px;
			display: flex;
			flex-wrap: wrap;
			gap: 10px 16px;
			font-size: 0.95rem;
		}

		.links a {
			color: #fde68a;
			text-decoration: none;
		}

		.links a:hover {
			text-decoration: underline;
		}

		@media (max-width: 840px) {
			.card {
				grid-template-columns: 1fr;
			}

			.form-panel {
				border-left: 0;
				border-top: 1px solid var(--panel-border);
			}
		}

		@media (max-width: 640px) {
			.hero,
			.form-panel {
				padding: 28px;
			}

			.form-actions { flex-direction: column; gap: 12px; }

			.button {
				width: 100%;
			}
		}
	</style>
</head>
<body>
	<main class="card">
		<section class="hero">
			<span class="eyebrow">Create your account</span>
			<h1>Sign up</h1>
			<p class="lead">
				Create a new login, then use the sign-in page to reach the dashboard.
			</p>

		</section>

		<section class="form-panel">
			<h2>Create account</h2>
			<p>Enter the details that will be saved for sign-in.</p>

			<% if (typeof msg !== 'undefined' && msg) { %>
				<div class="message"><%= msg %></div>
			<% } %>

			<form action="/signUp" method="post">
				<div class="field">
					<label for="emailID">Email ID</label>
					<input type="email" id="emailID" name="emailID" placeholder="name@example.com" required>
				</div>

				<div class="field">
					<label for="password">Password</label>
					<input type="password" id="password" name="password" placeholder="Create a password" required>
				</div>

				<div class="field">
					<label for="confirmPassword">Confirm Password</label>
					<input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repeat your password" required>
				</div>

				<div class="field">
					<label for="adminCode">Admin Code</label>
					<input type="text" id="adminCode" name="adminCode" placeholder="Enter admin code" required>
				</div>

				<div class="form-actions">
					<button class="button button-primary" type="submit">Sign Up</button>
					<a class="button button-secondary" href="/">I already have an account</a>
				</div>
			</form>

		</section>
	</main>
</body>
</html>
